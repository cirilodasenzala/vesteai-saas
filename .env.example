# =========================================================
# VesteAI — Exemplo de variáveis de ambiente
# Copie para .env e preencha. Chaves vazias ativam o modo
# SIMULADO (FASHN / Stripe), permitindo rodar tudo localmente.
# =========================================================

# ---------- Core ----------
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# ---------- Banco de dados ----------
# Postgres (via docker-compose). Para começar sem Docker, use DB_DRIVER=sqlite.
DB_DRIVER=postgres
DATABASE_URL=postgresql://vesteai:vesteai@localhost:5432/vesteai?schema=public
# Alternativa SQLite (sem servidor): DATABASE_URL="file:./prisma/dev.db"

# ---------- Redis / Fila ----------
# QUEUE_DRIVER=memory roda a fila em memória (sem Redis) para dev rápido.
QUEUE_DRIVER=redis
REDIS_HOST=localhost
REDIS_PORT=6379
WORKER_CONCURRENCY=2

# ---------- Segurança ----------
JWT_SECRET=troque-este-segredo
JWT_EXPIRES=1d
# Chave AES-256-GCM em base64 (32 bytes). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PII_ENCRYPTION_KEY=

# ---------- WhatsApp via Evolution API ----------
# Vazio => modo SIMULADO (envios apenas logados). Em produção, aponte
# EVOLUTION_BASE_URL para o serviço Evolution (rede interna do EasyPanel).
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
# Opcional: segredo p/ validar o webhook (header "apikey" ou ?token=).
EVOLUTION_WEBHOOK_TOKEN=

# ---------- IA Stylist (Google Gemini via @google/genai) ----------
# AI_DRIVER=mock usa respostas determinísticas (sem chave) para testes.
AI_DRIVER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
#
# Escolha UM modo de autenticação:
#
# (A) AI Studio — chave "AIza..." (mais simples, grátis):
#     GEMINI_USE_VERTEX=false  +  GEMINI_API_KEY=AIza...
#
# (B) Vertex AI com Service Account (JSON da conta de serviço):
#     GEMINI_USE_VERTEX=true
#     GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}
#     GEMINI_VERTEX_PROJECT=seu-project-id   (ou deixa vazio p/ usar o do JSON)
#     GEMINI_VERTEX_LOCATION=us-central1
#     (SA precisa do papel roles/aiplatform.user e da API aiplatform.googleapis.com)
#
GEMINI_USE_VERTEX=false
GEMINI_API_KEY=
GOOGLE_CREDENTIALS_JSON=
GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_LOCATION=us-central1

# ---------- Provador Virtual (FASHN) ----------
# Vazio => SimulatedTryOnProvider
FASHN_API_KEY=
FASHN_BASE_URL=https://api.fashn.ai/v1

# ---------- Pagamento (Stripe) ----------
# Vazio => SimulatedPaymentProvider
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREMIUM_MONTHLY=
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# ---------- Armazenamento de objetos (S3 / MinIO) ----------
# STORAGE_DRIVER=local grava em ./.storage (sem MinIO) para dev rápido.
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=vesteai
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000

# ---------- i18n / Admin ----------
DEFAULT_LANGUAGE=PT
ADMIN_BOOTSTRAP_EMAIL=admin@vesteai.local
ADMIN_BOOTSTRAP_PASSWORD=troque-esta-senha
